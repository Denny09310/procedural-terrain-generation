@using System.Buffers
@using Core.Services
@implements IAsyncDisposable

@inject IJSRuntime JS

<canvas @ref="_element"
        class="fixed top-0 left-0 w-screen h-screen block outline-none z-0 touch-none bg-[#000b14]"></canvas>

@code
{
    private ElementReference _element;
    private IJSObjectReference? _module;
    private DotNetObjectReference<TerrainCanvas>? _reference;
    private TerrainWorld? _old;

    [Parameter] public TerrainWorld? World { get; set; }
    [Parameter] public int ChunkSize { get; set; } = 256;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                 "./Components/Shared/TerrainCanvas.razor.js");

            _reference = DotNetObjectReference.Create(this);

            await _module.InvokeVoidAsync("init", _element, _reference, ChunkSize);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_module != null && World != _old)
        {
            _old = World;
            await _module.InvokeVoidAsync("clearCache");
        }
    }

    /// <summary>
    /// Triggered by JavaScript. Computes data on a background worker,
    /// pushes it back to JS, and recycles the array without allocations.
    /// </summary>
    [JSInvokable]
    public async Task StartRendering(int chunkX, int chunkY)
    {
        if (World == null || _module == null) return;

        var buffer = ArrayPool<byte>.Shared.Rent(ChunkSize * ChunkSize);

        try
        {
            // Compute map calculations safely on a background thread pool worker
            await Task.Run(() =>
            {
                var chunk = World.GetChunk(chunkX, chunkY);

                int height = chunk.Cells.GetLength(0);
                int width = chunk.Cells.GetLength(1);
                int index = 0;

                for (int y = 0; y < height; y++)
                {
                    for (int x = 0; x < width; x++)
                    {
                        buffer[index++] = (byte)chunk.Cells[y, x].Biome;
                    }
                }
            });

            await _module.InvokeVoidAsync("endRendering", chunkX, chunkY, buffer);
        }
        finally
        {
            ArrayPool<byte>.Shared.Return(buffer);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _reference?.Dispose();
        if (_module != null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}