@using System.Buffers
@using Core.Models
@using Core.Services
@implements IAsyncDisposable

@inject IJSRuntime JS

<canvas @ref="_element"
        class="fixed top-0 left-0 w-screen h-screen block outline-none z-0 touch-none bg-background"></canvas>

@code
{
    private ElementReference _element;
    private IJSObjectReference? _module;
    private DotNetObjectReference<TerrainCanvas>? _reference;
    private TerrainWorld? _old;

    [Parameter] public TerrainWorld? World { get; set; }
    [Parameter] public int ChunkSize { get; set; } = 128;
    [Parameter] public int TileSize { get; set; } = 4;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                 "./Components/Shared/TerrainCanvas.razor.js");

            _reference = DotNetObjectReference.Create(this);

            await _module.InvokeVoidAsync("init", _element, _reference, new
            {
                ChunkSize,
                TileSize
            });
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_module != null && World != _old)
        {
            _old = World;
            await _module.InvokeVoidAsync("clearCache");
        }
    }

    /// <summary>
    /// Triggered by JavaScript. Computes map data on a background worker,
    /// pushes both biomes and structures to JS, and recycles arrays without allocations.
    /// </summary>
    [JSInvokable]
    public async Task StartRendering(int chunkX, int chunkY)
    {
        if (World == null || _module == null) return;

        int totalCells = ChunkSize * ChunkSize;

        var biomes = ArrayPool<byte>.Shared.Rent(totalCells);
        var structures = ArrayPool<byte>.Shared.Rent(totalCells);

        try
        {
            // Compute map calculations safely on a background thread pool worker
            await Task.Run(() =>
            {
                var chunk = World.LoadChunk(chunkX, chunkY);

                int height = chunk.Cells.GetLength(0);
                int width = chunk.Cells.GetLength(1);
                int index = 0;

                for (int y = 0; y < height; y++)
                {
                    for (int x = 0; x < width; x++)
                    {
                        ref var cell = ref chunk.Cells[y, x];

                        biomes[index] = (byte)cell.Biome;
                        structures[index] = (byte)cell.Structure;
                        index++;
                    }
                }
            });

            await _module.InvokeVoidAsync(
                "endRendering",
                chunkX,
                chunkY,
                biomes,
                structures);
        }
        finally
        {
            ArrayPool<byte>.Shared.Return(biomes);
            ArrayPool<byte>.Shared.Return(structures);
        }
    }

    [JSInvokable]
    public Task UnloadChunks(ChunkCoordinates[] coordinates)
    {
        World?.UnloadChunks(coordinates);

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _reference?.Dispose();
        if (_module != null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
        }
    }
}