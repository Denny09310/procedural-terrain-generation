@page "/"

@using static Core.Helpers.ElevationHelpers
@using static Core.Helpers.MoistureHelpers
@using static Core.Helpers.TemperatureHelpers
@using static Core.Helpers.RiversHelpers
@using static Core.Helpers.TerrainHelpers

@using Client.Components.Shared
@using Core.Models
@using Core.Services

@if (_world != null)
{
    <TerrainCanvas World="_world" ChunkSize="256" />
}
else
{
    <div
        class="fixed inset-0 flex items-center justify-center bg-[#000b14] text-slate-300 font-mono text-lg tracking-wider select-none">
        <div class="flex items-center gap-3">
            <div class="w-5 h-5 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
            <span>Generating dynamic world matrix...</span>
        </div>
    </div>
}

@code
{
    private TerrainWorld? _world;

    protected override void OnInitialized()
    {
        _world = new TerrainBuilder(256, seed: 98765)
            .WithSettings(settings => settings with { Shape = TerrainShape.Archipelago })
            .WithTransformer(AddElevation)
            .WithTransformer(AddMoisture)
            .WithTransformer(AddTemperature)
            .WithTransformer(GenerateRivers)
            .WithTransformer(RecalculateMoisture)
            .WithTransformer(ClassifyTerrain)
            .Build();
    }
}